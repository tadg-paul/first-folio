#!/usr/bin/env perl
# ABOUTME: Convert org-mode play to clean Markdown with no pandoc involvement.
# ABOUTME: Produces idiomatic Markdown: headers, italic stage directions, bold character names.
use strict;
use warnings;
use utf8;
use open ':std', ':encoding(UTF-8)';

use FindBin;
use lib "$FindBin::RealBin/lib";

use File::Basename qw(dirname);
use Getopt::Long qw(:config no_ignore_case bundling);

use OrgPlay::Parser;
use Folio::Config;

our $VERSION = '0.1.0';

my $output  = '';
my $help    = 0;
my $version = 0;

GetOptions(
    'output|o=s' => \$output,
    'help|h'     => \$help,
    'version'    => \$version,
) or do { print_usage(); exit 2; };

if ($version) {
    print "org-play-to-markdown $VERSION\n";
    exit 0;
}

if ($help) {
    print_usage();
    exit 0;
}

# Determine input source
my $input_file = shift @ARGV;
my $fh;

if (defined $input_file) {
    if (! -f $input_file) {
        die "Error: file not found: $input_file\n";
    }
    open($fh, '<:encoding(UTF-8)', $input_file)
        or die "Error: cannot open $input_file: $!\n";
} else {
    $fh = \*STDIN;
}

# Load config
my $source_dir = defined $input_file ? dirname($input_file) : undef;
my $config = Folio::Config->load(source_dir => $source_dir);

# Determine output destination
my $out_fh;
if ($output ne '') {
    open($out_fh, '>:encoding(UTF-8)', $output)
        or die "Error: cannot write to $output: $!\n";
} else {
    $out_fh = \*STDOUT;
}

# Collect front matter first pass, then emit markdown
my %front_matter;
my @md_lines;
my $needs_blank = 0;  # whether we need a blank line before next block

my $emit_blank = sub {
    if ($needs_blank) {
        push @md_lines, '';
        $needs_blank = 0;
    }
};

my $in_char_table = 0;
my @char_table_rows;
my %footnotes;  # name => definition text

my $emitter = {
    front_matter => sub {
        my ($key, $value) = @_;
        $front_matter{$key} = $value;
    },
    act_header => sub {
        my ($title) = @_;
        $emit_blank->();
        push @md_lines, "## $title";
        $needs_blank = 1;
    },
    scene_header => sub {
        my ($title) = @_;
        $emit_blank->();
        push @md_lines, "### $title";
        $needs_blank = 1;
    },
    stage_direction => sub {
        my ($text) = @_;
        $emit_blank->();
        push @md_lines, "*" . _convert_org_markup($text) . "*";
        $needs_blank = 1;
    },
    character => sub {
        my ($name, $direction) = @_;
        $emit_blank->();
        if (defined $direction) {
            push @md_lines, "**${name}:** *(${direction})*";
        } else {
            push @md_lines, "**${name}:**";
        }
        $needs_blank = 0;  # dialogue follows immediately
    },
    dialogue => sub {
        my ($line) = @_;
        push @md_lines, _convert_org_markup($line);
        $needs_blank = 1;
    },
    character_table_start => sub {
        $in_char_table = 1;
        @char_table_rows = ();
    },
    character_table_row => sub {
        my ($name, $desc) = @_;
        push @char_table_rows, [$name, $desc];
    },
    character_table_end => sub {
        if (@char_table_rows) {
            $emit_blank->();
            # Find max widths for alignment
            my $max_name = 4;  # minimum "Name"
            my $max_desc = 11; # minimum "Description"
            for my $row (@char_table_rows) {
                my $nlen = length($row->[0]);
                my $dlen = length($row->[1]);
                $max_name = $nlen if $nlen > $max_name;
                $max_desc = $dlen if $dlen > $max_desc;
            }
            # Header
            push @md_lines, sprintf("| %-${max_name}s | %-${max_desc}s |", 'Character', 'Description');
            push @md_lines, sprintf("|-%s-|-%s-|", '-' x $max_name, '-' x $max_desc);
            for my $row (@char_table_rows) {
                push @md_lines, sprintf("| %-${max_name}s | %-${max_desc}s |", $row->[0], $row->[1]);
            }
            $needs_blank = 1;
        }
        $in_char_table = 0;
    },
    prop_text => sub {
        my ($text) = @_;
        $emit_blank->();
        push @md_lines, "***\"${text}\"***";
        $needs_blank = 1;
    },
    footnote_def => sub {
        my ($name, $text) = @_;
        $footnotes{$name} = $text;
    },
    end => sub {
        # nothing to close
    },
};

# Apply render-* filtering
my $filtered_emitter = _filter_emitter_by_config($emitter, $config);

OrgPlay::Parser->parse($fh, $filtered_emitter);

close $fh if defined $input_file;

# Apply config metadata overrides (config overrides source document)
for my $key (qw(title subtitle author draft-date)) {
    my $cfg_val = $config->get($key);
    if (defined $cfg_val) {
        $front_matter{$key} = $cfg_val;
    }
}

# Post-process: convert org footnote references to markdown format
if (%footnotes) {
    for my $i (0 .. $#md_lines) {
        $md_lines[$i] =~ s/\[fn:(\S+?)\]/
            exists $footnotes{$1}
                ? "[^$1]"
                : "[fn:$1]"
        /ge;
    }
}

# Build final output
my @output_lines;

# Title and author
if (my $title = $front_matter{title}) {
    push @output_lines, "# $title";
    if (my $author = $front_matter{author}) {
        push @output_lines, '';
        push @output_lines, "*by ${author}*";
    }
    push @output_lines, '';
}

push @output_lines, @md_lines;

# Append footnote definitions
if (%footnotes) {
    push @output_lines, '';
    for my $name (sort keys %footnotes) {
        push @output_lines, "[^$name]: $footnotes{$name}";
    }
}

# Ensure trailing newline
my $result = join("\n", @output_lines) . "\n";

print $out_fh $result;

if ($output ne '') {
    close $out_fh;
}

exit 0;

# Convert org inline markup to Markdown: /italic/ -> *italic*, *bold* -> **bold**
sub _convert_org_markup {
    my ($text) = @_;
    # Org bold *text* -> Markdown **text** (do bold first to avoid conflict with italic)
    $text =~ s{(?<!\w)\*([^*\n]+?)\*(?!\w)}{**${1}**}g;
    # Org italic /text/ -> Markdown *text*
    $text =~ s{(?<!\w)/([^/\n]+?)/(?!\w)}{*${1}*}g;
    return $text;
}

# Filter emitter callbacks based on render-* config keys.
sub _filter_emitter_by_config {
    my ($base, $cfg) = @_;
    my %filtered = %$base;

    if (!$cfg->get('render-stage-directions')) {
        $filtered{stage_direction} = sub {};
    }
    if (!$cfg->get('render-character-table')) {
        $filtered{character_table_start} = sub {};
        $filtered{character_table_row}   = sub {};
        $filtered{character_table_end}   = sub {};
    }
    if (!$cfg->get('render-footnotes')) {
        $filtered{footnote_def} = sub {};
    }

    return \%filtered;
}

sub print_usage {
    print <<'USAGE';
Usage: org-play-to-markdown [OPTIONS] [FILE]

Convert an org-mode play to clean Markdown.
Reads from FILE or stdin if no file given.
Output goes to stdout by default.

Options:
  -o, --output FILE   Write to FILE instead of stdout
  -h, --help          Show this help message
  --version           Show version
USAGE
}
