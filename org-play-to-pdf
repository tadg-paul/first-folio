#!/usr/bin/env perl
# ABOUTME: Convert org-mode play to PDF via Typst, using British stage play formatting.
# ABOUTME: Supports configurable fonts, margins, page size, and dialogue indent depth.
use strict;
use warnings;
use utf8;
use open ':std', ':encoding(UTF-8)';

use FindBin;
use lib "$FindBin::RealBin/lib";

use File::Temp qw(tempfile);
use File::Basename qw(basename dirname fileparse);
use Getopt::Long qw(:config no_ignore_case bundling);

use OrgPlay::Parser;
use OrgPlay::TypstTemplate;
use Folio::Config;

our $VERSION = '0.1.0';

# CLI-only flags (not part of config)
my $output            = '';
my $keep_typ          = 0;
my $typ_only          = 0;
my $help              = 0;
my $version           = 0;

# CLI overrides for config values — only populated when flags are given
my %cli_overrides;

GetOptions(
    'font=s'              => \$cli_overrides{'font'},
    'font-size=s'         => \$cli_overrides{'font-size'},
    'margin=s'            => \$cli_overrides{'margin'},
    'page=s'              => \$cli_overrides{'page'},
    'indent=s'            => \$cli_overrides{'indent'},
    'dialogue-spacing=s'  => \$cli_overrides{'dialogue-spacing'},
    'direction-spacing=s' => \$cli_overrides{'direction-spacing'},
    'direction-italic!'   => \$cli_overrides{'direction-italic'},
    'direction-center!'   => \$cli_overrides{'direction-center'},
    'output|o=s'          => \$output,
    'keep-typ'            => \$keep_typ,
    'typ-only'            => \$typ_only,
    'help|h'              => \$help,
    'version'             => \$version,
) or do { print_usage(); exit 2; };

if ($version) {
    print "org-play-to-pdf $VERSION\n";
    exit 0;
}

if ($help) {
    print_usage();
    exit 0;
}

# Determine input source
my $input_file = shift @ARGV;
my $fh;

if (defined $input_file) {
    if (! -f $input_file) {
        die "Error: file not found: $input_file\n";
    }
    open($fh, '<:encoding(UTF-8)', $input_file)
        or die "Error: cannot open $input_file: $!\n";
} else {
    $fh = \*STDIN;
}

# Load config: built-in defaults < global script.yaml < local script.yaml < CLI flags
my $source_dir = defined $input_file ? dirname($input_file) : undef;
my $config = Folio::Config->load(
    source_dir => $source_dir,
    cli        => \%cli_overrides,
);

# Resolve folio: config values into local variables for use below
my $font              = $config->get('folio.font');
my $font_size         = $config->get('folio.font-size');
my $margin            = $config->get('folio.margin');
my $page              = $config->get('folio.page');
my $indent            = $config->get('folio.indent');
my $dialogue_spacing  = $config->get('folio.dialogue-spacing');
my $direction_spacing = $config->get('folio.direction-spacing');
my $direction_italic  = $config->get('folio.direction-italic');
my $direction_center  = $config->get('folio.direction-center');

# Determine output path
if ($output eq '' && defined $input_file) {
    my ($name, $dir, $ext) = fileparse($input_file, qr/\.[^.]*/);
    if ($typ_only) {
        $output = "${dir}${name}.typ";
    } else {
        $output = "${dir}${name}.pdf";
    }
} elsif ($output eq '') {
    if ($typ_only) {
        $output = 'output.typ';
    } else {
        $output = 'output.pdf';
    }
}

# If --typ-only and output ends in .pdf, change to .typ
if ($typ_only && $output =~ /\.pdf$/) {
    $output =~ s/\.pdf$/.typ/;
}

# Collect front matter, then generate Typst
my %front_matter;
my @typst_body;
my $in_dialogue = 0;
my %footnotes;  # name => definition text

my $emitter = {
    front_matter => sub {
        my ($key, $value) = @_;
        $front_matter{$key} = $value;
    },
    act_header => sub {
        my ($title) = @_;
        push @typst_body, "#act-header[${title}]";
    },
    scene_header => sub {
        my ($title) = @_;
        push @typst_body, "#scene-header[${title}]";
    },
    stage_direction => sub {
        my ($text) = @_;
        # Escape Typst special chars in text
        my $escaped = _escape_typst($text);
        push @typst_body, "#stage-direction[${escaped}]";
    },
    character => sub {
        my ($name, $direction) = @_;
        $in_dialogue = 1;
        my $dir_arg = '';
        if (defined $direction) {
            my $escaped_dir = _escape_typst($direction);
            $dir_arg = ", direction: \"${escaped_dir}\"";
        }
        push @typst_body, "#dialogue(\"${name}\"${dir_arg})[";
    },
    dialogue => sub {
        my ($line) = @_;
        my $escaped = _escape_typst($line);
        if ($in_dialogue) {
            push @typst_body, "${escaped}";
        } else {
            # Prose text under H1/H2 headers (outline, setting, themes, etc.)
            push @typst_body, "${escaped}\n";
        }
    },
    character_table_start => sub {
        push @typst_body, '#align(center)[';
        push @typst_body, '#table(';
        push @typst_body, '  columns: 2,';
        push @typst_body, '  align: (left, left),';
        push @typst_body, '  stroke: 0.5pt,';
    },
    character_table_row => sub {
        my ($name, $desc) = @_;
        my $esc_name = _escape_typst($name);
        my $esc_desc = _escape_typst($desc);
        push @typst_body, "  [*${esc_name}*], [${esc_desc}],";
    },
    character_table_end => sub {
        push @typst_body, ')';
        push @typst_body, ']';
    },
    prop_text => sub {
        my ($text) = @_;
        my $escaped = _escape_typst($text);
        push @typst_body, "#prop-text[${escaped}]";
    },
    footnote_def => sub {
        my ($name, $text) = @_;
        $footnotes{$name} = $text;
    },
    end => sub {
        # Close any open dialogue block
        if ($in_dialogue) {
            push @typst_body, ']';
            $in_dialogue = 0;
        }
    },
};

# Apply render-* filtering: suppress events based on config
my $filtered_emitter = _filter_emitter_by_config($emitter, $config);

# We need to close dialogue blocks before new events
# Wrap the emitter to auto-close dialogue
my $wrapped_emitter = _wrap_emitter_with_dialogue_close($filtered_emitter);

OrgPlay::Parser->parse($fh, $wrapped_emitter);

# Post-process: substitute footnote references with Typst footnotes
if (%footnotes) {
    for my $i (0 .. $#typst_body) {
        $typst_body[$i] =~ s/\[fn:(\S+?)\]/
            exists $footnotes{$1}
                ? '#footnote[' . _escape_typst($footnotes{$1}) . ']'
                : "[fn:$1]"
        /ge;
    }
}

close $fh if defined $input_file;

# Apply config metadata overrides (config overrides source document)
for my $key (qw(title subtitle author date version)) {
    my $cfg_val = $config->get($key);
    if (defined $cfg_val) {
        $front_matter{$key} = $cfg_val;
    }
}

# Assemble full Typst document
my $preamble = OrgPlay::TypstTemplate->preamble(config => $config);

my $title_page = OrgPlay::TypstTemplate->title_page(
    config   => $config,
    title    => $front_matter{title}        // '',
    subtitle => $front_matter{subtitle}     // '',
    author   => $front_matter{author}       // '',
    date     => $front_matter{date}         // '',
    version  => $front_matter{version}      // '',
);

my $typst_doc = $preamble . $title_page . join("\n", @typst_body) . "\n";

if ($typ_only) {
    # Write .typ file directly
    open(my $out_fh, '>:encoding(UTF-8)', $output)
        or die "Error: cannot write to $output: $!\n";
    print $out_fh $typst_doc;
    close $out_fh;
} else {
    # Write to temp .typ, compile to PDF
    my ($tmp_fh, $tmp_path) = tempfile('org-play-XXXX', SUFFIX => '.typ', TMPDIR => 1);
    binmode($tmp_fh, ':encoding(UTF-8)');
    print $tmp_fh $typst_doc;
    close $tmp_fh;

    my @cmd = ('typst', 'compile', $tmp_path, $output);
    system(@cmd) == 0
        or die "Error: typst compile failed (exit $?)\n";

    if ($keep_typ) {
        my $typ_output = $output;
        $typ_output =~ s/\.pdf$/.typ/;
        require File::Copy;
        File::Copy::copy($tmp_path, $typ_output)
            or die "Error: cannot copy .typ file: $!\n";
    }

    unlink $tmp_path;
}

exit 0;

# --- Helpers ---

sub _escape_typst {
    my ($text) = @_;

    # Convert org inline markup to placeholders before escaping.
    # /italic/ -> Typst _italic_, *bold* -> Typst *bold*
    # Use null bytes as placeholders since they won't appear in text.
    my @markup_slots;
    # Org italic: /text/ (not preceded/followed by space or at path boundaries)
    $text =~ s{(?<!\w)/([^/\n]+?)/(?!\w)}{
        push @markup_slots, "_${1}_";
        "\x00MARKUP" . $#markup_slots . "\x00"
    }ge;
    # Org bold: *text*
    $text =~ s{(?<!\w)\*([^*\n]+?)\*(?!\w)}{
        push @markup_slots, "*${1}*";
        "\x00MARKUP" . $#markup_slots . "\x00"
    }ge;

    # Escape Typst special characters in content text.
    # Order matters: backslash first, then others.
    $text =~ s/\\/\\\\/g;
    $text =~ s/_/\\_/g;
    $text =~ s/\*/\\*/g;
    $text =~ s/\$/\\\$/g;
    $text =~ s/@/\\@/g;
    # Don't escape # at start of function calls
    $text =~ s/(?<!^)#/\\#/g if $text !~ /^#/;

    # Restore markup placeholders (unescaped)
    $text =~ s/\x00MARKUP(\d+)\x00/$markup_slots[$1]/g;

    return $text;
}

sub _wrap_emitter_with_dialogue_close {
    my ($base) = @_;
    my $wrapped = {};

    # Events that close a dialogue block
    my @closers = qw(act_header scene_header stage_direction character
                      character_table_start prop_text end);

    for my $event (keys %$base) {
        if (grep { $_ eq $event } @closers) {
            $wrapped->{$event} = sub {
                if ($in_dialogue) {
                    push @typst_body, ']';
                    $in_dialogue = 0;
                }
                $base->{$event}->(@_);
            };
        } else {
            $wrapped->{$event} = $base->{$event};
        }
    }

    return $wrapped;
}

# Filter emitter callbacks based on render-* config keys.
# Returns a new emitter hashref with suppressed events replaced by no-ops.
sub _filter_emitter_by_config {
    my ($base, $cfg) = @_;
    my %filtered = %$base;

    if (!$cfg->get('render.stage-directions')) {
        $filtered{stage_direction} = sub {};
    }
    if (!$cfg->get('render.character-table')) {
        $filtered{character_table_start} = sub {};
        $filtered{character_table_row}   = sub {};
        $filtered{character_table_end}   = sub {};
    }
    if (!$cfg->get('render.footnotes')) {
        $filtered{footnote_def} = sub {};
    }

    return \%filtered;
}

sub print_usage {
    print <<'USAGE';
Usage: org-play-to-pdf [OPTIONS] [FILE]

Convert an org-mode play to PDF via Typst.
Reads from FILE or stdin if no file given.

Config: script.yaml in source dir or ~/.config/first-folio/script.yaml
CLI flags override config file values.

Options:
  --font FONT              Body font family (default: "New Computer Modern")
  --font-size SIZE         Body font size (default: 12pt)
  --margin SIZE            Page margins (default: 25mm)
  --page SIZE              Page size (default: a4)
  --indent SIZE            Dialogue indent depth (default: 4em)
  --dialogue-spacing SIZE  Space before dialogue blocks (default: 1em)
  --direction-spacing SIZE Space before stage directions (default: 1em)
  --[no-]direction-italic  Italicise stage directions (default: on)
  --[no-]direction-center  Centre stage directions (default: off)
  -o, --output FILE        Output path (default: <input>.pdf)
  --keep-typ               Retain the intermediate .typ file
  --typ-only               Emit .typ only, do not compile to PDF
  -h, --help               Show this help message
  --version                Show version
USAGE
}
